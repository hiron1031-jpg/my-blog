# ======================================
# 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、実際の値を入力してください
# .env.local は Git にコミットしませ��（.gitignore で除外済み）
# ======================================

# サイト情報（本番 URL に変更してください）
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_SITE_NAME=ビジネス知識ラボ
NEXT_PUBLIC_SITE_DESCRIPTION=ビジネスの最前線で役立つ専門知識を、わかりやすく解説するブログです。

# 著者情報
NEXT_PUBLIC_AUTHOR_NAME=管理者
NEXT_PUBLIC_AUTHOR_BIO=ビジネス・経営に関する専門知識を発信しています。

# お問い合わせフォーム（Web3Forms）
# 無料アカウント作成: https://web3forms.com
# ※ NEXT_PUBLIC_ プレフィックスは意図的なもの（Web3Forms キーはクライアント公開設計）
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_access_key_here

# Google Analytics（任意）
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
